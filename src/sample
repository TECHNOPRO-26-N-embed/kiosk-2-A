#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX_ITEMS 10
#define MAX_LINE_LENGTH 256

// 商品データ構造体
typedef struct {
    int id;
    char name[50];
    double price;
    char category[50];
    int stock;
    int tax_rate;
} Product;

// レシート表示機能
void display_receipt(const Product purchased_products[], const int quantities[], int item_count) {
    double total = 0.0;
    double tax_8 = 0.0;
    double tax_10 = 0.0;

    printf("\n--- レシート ---\n");
    for (int i = 0; i < item_count; i++) {
        double subtotal = quantities[i] * purchased_products[i].price;
        double tax = 0.0;

        // CSVの税率列を使用
        if (purchased_products[i].tax_rate == 8) {
            tax = subtotal * 0.08;
            tax_8 += tax;
        } else if (purchased_products[i].tax_rate == 10) {
            tax = subtotal * 0.10;
            tax_10 += tax;
        }

        total += subtotal + tax;
        printf("ID:%d %s x %d @ %.2f円 = %.2f円 (税 %.2f円)\n",
               purchased_products[i].id,
               purchased_products[i].name,
               quantities[i],
               purchased_products[i].price,
               subtotal + tax,
               tax);
    }

    printf("\n税率8%%: %.2f円\n", tax_8);
    printf("税率10%%: %.2f円\n", tax_10);
    printf("合計: %.2f円\n", total);
    printf("---\n\n");
}

// CSVファイルから商品データを読み込む
int load_products(const char* filename, Product products[], int max_products) {
    FILE* file = fopen(filename, "r");
    if (!file) {
        perror("Failed to open file");
        return 0;
    }

    char line[MAX_LINE_LENGTH];
    int count = 0;

    // ヘッダーをスキップ
    fgets(line, sizeof(line), file);

    while (fgets(line, sizeof(line), file) && count < max_products) {
        sscanf(line, "%d,%49[^,],%lf,%49[^,],%d,%d",
               &products[count].id,
               products[count].name,
               &products[count].price,
               products[count].category,
               &products[count].stock,
               &products[count].tax_rate);
        count++;
    }

    fclose(file);
    return count;
}

// 購入処理機能
void process_purchase() {
    Product products[MAX_ITEMS];
    Product purchased_products[MAX_ITEMS];
    int quantities[MAX_ITEMS];
    int product_count = load_products("data/Shouhin_DB.csv", products, MAX_ITEMS);
    if (product_count == 0) {
        product_count = load_products("../data/Shouhin_DB.csv", products, MAX_ITEMS);
    }

    if (product_count == 0) {
        printf("商品データの読み込みに失敗しました。\n");
        return;
    }

    int item_count = 0;

    while (1) {
        int product_id;
        int product_index = -1;
        int quantity;

        printf("\n--- 商品一覧 ---\n");
        for (int i = 0; i < product_count; i++) {
            printf("ID:%d | %s | %.0f円 | %s | 在庫:%d | 税率:%d%%\n",
                   products[i].id,
                   products[i].name,
                   products[i].price,
                   products[i].category,
                   products[i].stock,
                   products[i].tax_rate);
        }

        printf("商品IDを入力してください（終了するには0を入力）: ");
        scanf("%d", &product_id);

        if (product_id == 0) {
            break;
        }

        for (int i = 0; i < product_count; i++) {
            if (products[i].id == product_id) {
                product_index = i;
                break;
            }
        }

        if (product_index == -1) {
            printf("無効な商品IDです。\n");
            continue;
        }

        printf("数量を入力してください: ");
        scanf("%d", &quantity);

        if (quantity <= 0) {
            printf("数量は1以上を入力してください。\n");
            continue;
        }

        if (quantity > products[product_index].stock) {
            printf("在庫が不足しています。\n");
            continue;
        }

        if (item_count >= MAX_ITEMS) {
            printf("購入可能な商品数は最大%d件です。\n", MAX_ITEMS);
            break;
        }

        products[product_index].stock -= quantity;
        purchased_products[item_count] = products[product_index];
        quantities[item_count] = quantity;
        item_count++;
    }

    // レシート表示
    display_receipt(purchased_products, quantities, item_count);
}